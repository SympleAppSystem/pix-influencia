<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pix Premiado - Influência</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        /* ... SEU CSS ANTIGO FICA EXATAMENTE AQUI. PARA NÃO DEIXAR A MENSAGEM GIGANTE, COLEI APENAS A ESTRUTURA GERAL ... */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f0f2f5; margin: 0; padding: 20px; color: #333; }
        .container { max-width: 800px; margin: auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h1 { text-align: center; color: #1a73e8; }
        .grid-numeros { display: grid; grid-template-columns: repeat(auto-fill, minmax(60px, 1fr)); gap: 10px; margin-top: 20px; }
        .numero { background: #e0e0e0; border-radius: 8px; text-align: center; padding: 15px 0; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .numero.livre:hover { background: #1a73e8; color: white; }
        .numero.reservado { background: #ff9800; color: white; cursor: not-allowed; }
        .numero.pago { background: #4CAF50; color: white; cursor: not-allowed; }
        .numero.premiado { background: #FFD700; color: black; cursor: not-allowed; box-shadow: 0 0 10px #FFD700; }
        .btn-comprar { display: block; width: 100%; padding: 15px; background: #1a73e8; color: white; text-align: center; border: none; border-radius: 8px; font-size: 18px; margin-top: 20px; cursor: pointer; font-weight: bold; }
        #modalCompra { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); justify-content: center; align-items: center; }
        .modal-content { background: white; padding: 30px; border-radius: 12px; width: 90%; max-width: 400px; }
        .modal-content input { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }
        .modal-content button { width: 100%; padding: 12px; background: #4CAF50; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; margin-top: 10px; }
        .aviso-encerrado { display: none; background: #f44336; color: white; text-align: center; padding: 20px; font-size: 24px; font-weight: bold; border-radius: 8px; margin-bottom: 20px; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Sorteio Influência Modas</h1>
        
        <div id="avisoEncerrado" class="aviso-encerrado">
            🎉 EDIÇÃO ENCERRADA - SORTEIO REALIZADO 🎉
        </div>

        <div id="premiosContainer" style="margin-bottom: 30px; display: flex; gap: 10px; justify-content: space-between;">
            </div>

        <h3>Escolha seus números (Valor: R$ <span id="valorCota">0,00</span>):</h3>
        <p>Números selecionados: <span id="numerosSelecionadosTexto" style="font-weight: bold; color: #1a73e8;">Nenhum</span></p>
        
        <div class="grid-numeros" id="gridNumeros">Carregando painel de alta velocidade...</div>

        <button class="btn-comprar" id="btnComprar" onclick="abrirModal()">Finalizar Compra</button>
    </div>

    <div id="modalCompra">
        <div class="modal-content">
            <h2>Quase lá!</h2>
            <p>Você selecionou <span id="qtdModal">0</span> número(s).</p>
            <p>Total a pagar: R$ <span id="totalModal">0,00</span></p>
            <input type="text" id="nomeCliente" placeholder="Seu Nome Completo" required>
            <input type="tel" id="telefoneCliente" placeholder="WhatsApp (com DDD)" required>
            <button onclick="reservarNumeros()">Ir para Pagamento</button>
            <button onclick="fecharModal()" style="background: #f44336;">Cancelar</button>
        </div>
    </div>

    <script>
        // 🚨 CONFIGURAÇÃO DO BANCO DE DADOS SUPABASE 🚨
        const SUPABASE_URL = 'https://lukdkotczqindytggpvm.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imx1a2Rrb3RjenFpbmR5dGdncHZtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI5MzQ3NzMsImV4cCI6MjA5ODUxMDc3M30.YTx_2J0Ebr-fiXftPJqgvU90pRpkx664dKN9F2RxVjA';
        
        // Inicializa a conexão em milissegundos
        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        let edicaoAtual = "";
        let numerosSelecionados = [];
        let configEdicao = {};
        let todosOsNumeros = [];

        async function carregarTudo() {
            try {
                // 1. Descobrir qual é a Edição Ativa
                const { data: edicoes, error: erroEdicao } = await supabase
                    .from('gerenciador')
                    .select('*')
                    .or('status.ilike.ativa,status.ilike.pendente')
                    .limit(1);

                if (erroEdicao) throw erroEdicao;

                if (edicoes && edicoes.length > 0) {
                    configEdicao = edicoes[0];
                    edicaoAtual = configEdicao.nome_edicao;
                    document.getElementById('valorCota').innerText = configEdicao.valor_cota.replace('.', ',');

                    // Se a edição foi marcada como concluída/encerrada
                    let statusEd = configEdicao.status.toLowerCase();
                    if (statusEd === "concluída" || statusEd === "concluida" || statusEd === "encerrada") {
                        document.getElementById('avisoEncerrado').style.display = 'block';
                        document.getElementById('btnComprar').style.display = 'none';
                    }

                    // Renderizar Prêmios
                    let premiosHtml = "";
                    if(configEdicao.premio_1_titulo) premiosHtml += `<div style="background:#fff3cd; padding:10px; border-radius:8px; text-align:center; width:30%;">🥇 <b>1º Prêmio</b><br>${configEdicao.premio_1_titulo}</div>`;
                    if(configEdicao.premio_2_titulo) premiosHtml += `<div style="background:#e2e3e5; padding:10px; border-radius:8px; text-align:center; width:30%;">🥈 <b>2º Prêmio</b><br>${configEdicao.premio_2_titulo}</div>`;
                    if(configEdicao.premio_3_titulo) premiosHtml += `<div style="background:#f8d7da; padding:10px; border-radius:8px; text-align:center; width:30%;">🥉 <b>3º Prêmio</b><br>${configEdicao.premio_3_titulo}</div>`;
                    document.getElementById('premiosContainer').innerHTML = premiosHtml;

                    // 2. Carregar os bilhetes dessa edição
                    carregarBilhetes();
                } else {
                    document.getElementById('gridNumeros').innerHTML = "Nenhuma edição ativa no momento.";
                }
            } catch (error) {
                console.error('Erro ao carregar dados:', error);
                document.getElementById('gridNumeros').innerHTML = "Erro ao conectar com o banco de dados.";
            }
        }

        async function carregarBilhetes() {
            const { data: bilhetes, error } = await supabase
                .from('sorteio')
                .select('id, numero, status')
                .eq('edicao', edicaoAtual)
                .order('numero', { ascending: true });

            if (error) { console.error(error); return; }

            todosOsNumeros = bilhetes;
            renderizarGrid();
        }

        function renderizarGrid() {
            let gridHtml = '';
            let statusEd = configEdicao.status ? configEdicao.status.toLowerCase() : "ativa";
            let edicaoEncerrada = (statusEd === "concluída" || statusEd === "concluida" || statusEd === "encerrada");

            todosOsNumeros.forEach(bilhete => {
                let st = bilhete.status.toLowerCase();
                let classe = "numero " + st;
                
                // Se a edição encerrou, bloqueia tudo visualmente
                if (edicaoEncerrada && st === 'livre') {
                    classe += " reservado"; // finta visual
                }

                if (st === 'livre' && !edicaoEncerrada) {
                    if (numerosSelecionados.includes(bilhete.numero)) {
                        gridHtml += `<div class="numero livre" style="background:#1a73e8; color:white;" onclick="selecionarNumero(${bilhete.numero})">${bilhete.numero}</div>`;
                    } else {
                        gridHtml += `<div class="numero livre" onclick="selecionarNumero(${bilhete.numero})">${bilhete.numero}</div>`;
                    }
                } else {
                    gridHtml += `<div class="${classe}">${bilhete.numero}</div>`;
                }
            });
            document.getElementById('gridNumeros').innerHTML = gridHtml;
        }

        function selecionarNumero(num) {
            let index = numerosSelecionados.indexOf(num);
            if (index > -1) { numerosSelecionados.splice(index, 1); } 
            else { numerosSelecionados.push(num); }
            
            numerosSelecionados.sort((a, b) => a - b);
            document.getElementById('numerosSelecionadosTexto').innerText = numerosSelecionados.length > 0 ? numerosSelecionados.join(', ') : 'Nenhum';
            renderizarGrid();
        }

        function abrirModal() {
            if (numerosSelecionados.length === 0) { alert("Selecione pelo menos um número!"); return; }
            let total = numerosSelecionados.length * parseFloat(configEdicao.valor_cota.replace(',', '.'));
            document.getElementById('qtdModal').innerText = numerosSelecionados.length;
            document.getElementById('totalModal').innerText = total.toFixed(2).replace('.', ',');
            document.getElementById('modalCompra').style.display = 'flex';
        }

        function fecharModal() { document.getElementById('modalCompra').style.display = 'none'; }

        async function reservarNumeros() {
            let nome = document.getElementById('nomeCliente').value.trim();
            let tel = document.getElementById('telefoneCliente').value.trim();
            
            if (nome === "" || tel === "") { alert("Preencha seu nome e WhatsApp!"); return; }

            // Verifica se alguém comprou os números na mesma fração de segundo!
            const { data: verificacao, error: erroVerifica } = await supabase
                .from('sorteio')
                .select('numero, status')
                .in('numero', numerosSelecionados)
                .eq('edicao', edicaoAtual);

            if(erroVerifica) return;

            let roubados = verificacao.filter(b => b.status.toLowerCase() !== 'livre');
            if (roubados.length > 0) {
                alert("Ops! Alguém acabou de reservar alguns dos números que você escolheu. Por favor, selecione outros.");
                fecharModal();
                numerosSelecionados = [];
                document.getElementById('numerosSelecionadosTexto').innerText = 'Nenhum';
                carregarBilhetes(); // Recarrega a tela
                return;
            }

            // Atualiza os números para Reservado
            let dataAtual = new Date().toLocaleString("pt-BR");
            
            const { error: erroUpdate } = await supabase
                .from('sorteio')
                .update({ status: 'Reservado', nome: nome, whatsapp: tel, data: dataAtual })
                .in('numero', numerosSelecionados)
                .eq('edicao', edicaoAtual);

            if (erroUpdate) {
                alert("Erro ao processar reserva. Tente novamente.");
            } else {
                alert(`Sucesso! Você reservou os números: ${numerosSelecionados.join(', ')}. Redirecionando para o WhatsApp...`);
                
                // Manda para o seu WhatsApp (COLOQUE SEU NÚMERO AQUI NA VARIÁVEL SEU_ZAP)
                let SEU_ZAP = "5511999999999"; 
                let totalStr = document.getElementById('totalModal').innerText;
                let texto = `Olá! Acabei de reservar no site.\n\n*Nome:* ${nome}\n*Edição:* ${edicaoAtual}\n*Números (${numerosSelecionados.length}):* ${numerosSelecionados.join(', ')}\n*Total:* R$ ${totalStr}\n\nSegue o meu comprovante do Pix!`;
                
                window.location.href = `https://wa.me/${SEU_ZAP}?text=${encodeURIComponent(texto)}`;
            }
        }

        // Inicia o sistema
        carregarTudo();
    </script>
</body>
</html>
